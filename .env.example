# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Supabase Project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase Service-Role Key (NOT the anon key — service role bypasses RLS)
SUPABASE_KEY=

# Your personal Telegram User ID (integer). Only this user can run /stats, /broadcast, /get_link.
OWNER_ID=

# A random secret string used as the webhook path segment (e.g. a UUID).
# The webhook URL becomes: https://<VERCEL_URL>/webhook
WEBHOOK_SECRET=

# Vercel auto-provides VERCEL_URL at runtime.  You don't need to set it manually,
# but if you're testing locally you can override it here.
# VERCEL_URL=localhost:8000
